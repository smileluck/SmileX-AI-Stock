    {
      "label": "AKShare Interface Naming Convention",
      "file_type": "rationale",
      "source_file": "akshare-docs/contributing.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Interface naming follows pattern: product_country_market_datasource (e.g. stock_zh_a_hist_sina). This provides self-documenting API names that convey asset type, geography, market, data type, and source at a glance.",
      "id": "interface_naming_convention",
      "community": 0,
      "norm_label": "akshare interface naming convention"
    },
    {
      "label": "DataFrame Return Format",
      "file_type": "rationale",
      "source_file": "akshare-docs/contributing.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "All AKShare interfaces return pandas.DataFrame to ensure compatibility with HTTP API interfaces (AKTools) and provide a uniform data structure for downstream processing. Field types restricted to int64, float64, object.",
